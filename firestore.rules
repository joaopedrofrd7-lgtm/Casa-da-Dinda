rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Product Rules
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.cost is number && data.cost >= 0
        && data.stock is number
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp;
    }

    match /products/{productId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidProduct(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.ownerId) && isValidProduct(request.resource.data);
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // Board Rules
    function isValidBoard(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.cost is number && data.cost >= 0
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp;
    }

    match /boards/{boardId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidBoard(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.ownerId) && isValidBoard(request.resource.data);
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // Production Rules
    function isValidProduction(data) {
      return data.finalProductName is string && data.finalProductName.size() > 0
        && data.boardId is string
        && data.items is list
        && data.totalCost is number
        && data.ownerId == request.auth.uid
        && data.createdAt is timestamp;
    }

    match /productions/{productionId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidProduction(request.resource.data);
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }
  }
}
